{
  "name": "vtrack-node-sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the Vtrack API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vtrack",
    "fitness",
    "api",
    "sdk"
  ],
  "author": "Vtrackgym",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vtrackgym/vtrack-node"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}